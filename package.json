{
  "name": "transfer-desk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "relay": "relay-compiler",
    "schema:fetch": "npx get-graphql-schema http://localhost:8080/v1/graphql -h 'x-hasura-admin-secret=adminsecretkey' > schema.graphql",
    "codegen": "pnpm schema:fetch && pnpm relay",
    "relay:watch": "relay-compiler --watch",
    "relay:clean": "rm -rf __generated__",
    "check:format": "prettier --check \"**/*.{ts,tsx}\"",
    "check:types": "tsc --noEmit",
    "check:lint": "pnpm run lint",
    "check:all": "pnpm run check:format && pnpm run check:lint && pnpm run check:types",
    "fix:format": "pnpm run format",
    "fix:lint": "eslint --fix",
    "fix:all": "pnpm run fix:format && pnpm run fix:lint",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "danger:prisma-reset": "prisma migrate reset",
    "hasura:console": "echo 'Hasura CLI required. Install it to use this script, or visit http://localhost:8080'",
    "hasura:apply": "echo 'Hasura metadata project required. Initialize with hasura init.'",
    "clean:next": "rm -rf .next",
    "clean:all": "pnpm run relay:clean && pnpm run clean:next",
    "setup:local": "pnpm run docker:up && pnpm run prisma:generate && pnpm run codegen"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.12.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-relay": "^20.1.1",
    "relay-runtime": "^20.1.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-relay": "^18.2.1",
    "@types/relay-runtime": "^20.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "get-graphql-schema": "^2.1.2",
    "prettier": "^3.8.1",
    "prisma": "^7.4.0",
    "relay-compiler": "^20.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
